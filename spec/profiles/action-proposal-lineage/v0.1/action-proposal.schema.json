{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://homeworldmodel.org/spec/profiles/action-proposal-lineage/v0.1/action-proposal.schema.json",
  "title":"HWM Action Proposal v0.1",
  "type":"object",
  "required":["contract","contract_version","proposal_id","proposal_revision","proposal_digest_scope","proposal_digest","previous_proposal_binding","identity_basis","proposed_by","realization","based_on_world_view_binding","plan_binding","action","precondition_claim_bindings","effect_claim_bindings","impact_bindings","validity","created_at","proof","extensions"],
  "properties":{
    "contract":{"const":"hwm-proposal:ActionProposal"},
    "contract_version":{"const":"0.1.0"},
    "proposal_id":{"type":"string","minLength":1},
    "proposal_revision":{"type":"integer","minimum":1},
    "proposal_digest_scope":{"const":"canonical_projection_without_proposal_digest_and_proof"},
    "proposal_digest":{"$ref":"#/$defs/Digest"},
    "previous_proposal_binding":{"oneOf":[{"type":"null"},{"$ref":"#/$defs/ProposalBinding"}]},
    "identity_basis":{
      "type":"object",
      "required":["household_id","intent_binding","realization_identity","purpose","semantic_action_kind","target_refs"],
      "properties":{
        "household_id":{"type":"string","minLength":1},
        "intent_binding":{"$ref":"#/$defs/Binding"},
        "realization_identity":{"$ref":"#/$defs/Binding"},
        "purpose":{"type":"string","minLength":1},
        "semantic_action_kind":{"type":"string","minLength":1},
        "target_refs":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}}
      },
      "additionalProperties":false
    },
    "proposed_by":{"type":"string","minLength":1},
    "realization":{
      "type":"object",
      "required":["mode","routing_assessment_binding","task_binding"],
      "properties":{
        "mode":{"enum":["direct","task"]},
        "routing_assessment_binding":{"$ref":"#/$defs/Binding"},
        "task_binding":{"oneOf":[{"type":"null"},{"$ref":"#/$defs/Binding"}]}
      },
      "allOf":[
        {"if":{"properties":{"mode":{"const":"task"}}},"then":{"properties":{"task_binding":{"$ref":"#/$defs/Binding"}}}},
        {"if":{"properties":{"mode":{"const":"direct"}}},"then":{"properties":{"task_binding":{"type":"null"}}}}
      ],
      "additionalProperties":false
    },
    "based_on_world_view_binding":{"$ref":"#/$defs/Binding"},
    "plan_binding":{"oneOf":[{"type":"null"},{"$ref":"#/$defs/Binding"}]},
    "action":{
      "type":"object",
      "required":["operation","parameters"],
      "properties":{"operation":{"type":"string","minLength":1},"parameters":{"type":"object"}},
      "additionalProperties":false
    },
    "precondition_claim_bindings":{"type":"array","uniqueItems":true,"items":{"$ref":"#/$defs/Binding"}},
    "effect_claim_bindings":{"type":"array","uniqueItems":true,"items":{"$ref":"#/$defs/Binding"}},
    "impact_bindings":{"type":"array","uniqueItems":true,"items":{"$ref":"#/$defs/Binding"}},
    "validity":{
      "type":"object","required":["not_before","expires_at"],
      "properties":{"not_before":{"type":["string","null"],"format":"date-time"},"expires_at":{"type":["string","null"],"format":"date-time"}},
      "additionalProperties":false
    },
    "created_at":{"type":"string","format":"date-time"},
    "proof":{"$ref":"#/$defs/Proof"},
    "extensions":{"type":"object"}
  },
  "$defs":{
    "Digest":{"type":"string","pattern":"^[0-9a-f]{64}$"},
    "Binding":{"type":"object","required":["artifact_id","revision","digest_algorithm","canonicalization","digest"],"properties":{"artifact_id":{"type":"string","minLength":1},"revision":{"type":"integer","minimum":1},"digest_algorithm":{"const":"sha-256"},"canonicalization":{"const":"RFC8785"},"digest":{"$ref":"#/$defs/Digest"}},"additionalProperties":false},
    "ProposalBinding":{"type":"object","required":["proposal_id","proposal_revision","digest_algorithm","canonicalization","digest"],"properties":{"proposal_id":{"type":"string","minLength":1},"proposal_revision":{"type":"integer","minimum":1},"digest_algorithm":{"const":"sha-256"},"canonicalization":{"const":"RFC8785"},"digest":{"$ref":"#/$defs/Digest"}},"additionalProperties":false},
    "Proof":{"type":"object","required":["mode","verification_method","value"],"properties":{"mode":{"enum":["unsigned_fixture","jws","cose","vc"]},"verification_method":{"type":"string","minLength":1},"value":{"type":"string","minLength":1}},"additionalProperties":false}
  },
  "allOf":[
    {"if":{"properties":{"proposal_revision":{"const":1}}},"then":{"properties":{"previous_proposal_binding":{"type":"null"}}}},
    {"if":{"properties":{"proposal_revision":{"type":"integer","minimum":2}}},"then":{"properties":{"previous_proposal_binding":{"$ref":"#/$defs/ProposalBinding"}}}}
  ],
  "additionalProperties":false
}
