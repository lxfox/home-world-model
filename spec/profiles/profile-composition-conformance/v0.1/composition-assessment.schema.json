{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://homeworldmodel.org/spec/profiles/profile-composition-conformance/v0.1/composition-assessment.schema.json",
  "title":"HWM Composition Assessment v0.1",
  "type":"object",
  "required":["assessment_id","conformance_set_ref","as_of","checks","overall","limitations","must_not_infer"],
  "properties":{
    "assessment_id":{"type":"string","minLength":1},
    "conformance_set_ref":{"type":"string","minLength":1},
    "as_of":{"type":"string","format":"date-time"},
    "checks":{"type":"array","minItems":1,"items":{"type":"object","required":["check_kind","status","evidence_refs"],"properties":{"check_kind":{"enum":["descriptor_integrity","offline_resolution","dependency_closure","version_resolution","lock_consistency","incompatibility","required_cycle","artifact_coverage","role_evidence","invariant_coverage","unknown_extensions","degradation"]},"status":{"enum":["satisfied","satisfied_with_limits","not_satisfied","indeterminate"]},"evidence_refs":{"type":"array","items":{"type":"string"},"uniqueItems":true},"limitations":{"type":"array","items":{"type":"string"}}},"additionalProperties":false}},
    "overall":{"enum":["conformant","conformant_with_limits","not_conformant","indeterminate"]},
    "effective_degradation":{"type":["string","null"],"enum":["read_only_limited","opaque_relay","qualified_mediator_required","refuse_unsupported_operation",null]},
    "limitations":{"type":"array","items":{"type":"string"}},
    "must_not_infer":{"type":"array","minItems":1,"items":{"type":"string"},"uniqueItems":true}
  },
  "additionalProperties":false
}
