{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homeworldmodel.org/spec/profiles/physical-asset-onboarding/v0.1/asset-onboarding-bundle.schema.json",
  "title": "HWM Asset Onboarding Bundle v0.1",
  "type": "object",
  "required": ["bundle_id", "household_ref", "purpose", "candidate_asset_ref", "evidence_items", "origin_groups", "created_at"],
  "properties": {
    "bundle_id": {"type": "string", "minLength": 1},
    "household_ref": {"type": "string", "minLength": 1},
    "purpose": {"type": "string", "minLength": 1},
    "candidate_asset_ref": {"type": "string", "minLength": 1},
    "acquisition_basis_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "product_model_candidates": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "variant_candidates": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "intended_function_position_ref": {"type": ["string", "null"]},
    "candidate_endpoint_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "evidence_items": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["evidence_ref", "kind", "origin_id", "standing_decision_ref"], "properties": {"evidence_ref": {"type": "string"}, "kind": {"type": "string"}, "origin_id": {"type": "string"}, "standing_decision_ref": {"type": ["string", "null"]}, "valid_time": {"type": ["string", "null"]}}, "additionalProperties": true}},
    "origin_groups": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["origin_id", "evidence_refs"], "properties": {"origin_id": {"type": "string"}, "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true}}, "additionalProperties": false}},
    "disclosure_policy_ref": {"type": ["string", "null"]},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
