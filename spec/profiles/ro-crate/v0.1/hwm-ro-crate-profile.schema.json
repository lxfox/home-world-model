{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homeworldmodel.org/spec/profiles/ro-crate/v0.1/hwm-ro-crate-profile.schema.json",
  "title": "HWM RO-Crate Profile v0.1 candidate JSON shape",
  "type": "object",
  "required": ["@context", "@graph"],
  "properties": {
    "@context": {
      "oneOf": [
        { "const": "https://w3id.org/ro/crate/1.3/context" },
        {
          "type": "array",
          "minItems": 2,
          "contains": { "const": "https://w3id.org/ro/crate/1.3/context" },
          "items": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              { "type": "object", "minProperties": 1 }
            ]
          }
        }
      ]
    },
    "@graph": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["@id", "@type"],
        "properties": {
          "@id": { "type": "string", "minLength": 1 },
          "@type": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
            ]
          }
        },
        "additionalProperties": true
      },
      "allOf": [
        {
          "contains": {
            "type": "object",
            "required": ["@id", "@type", "about", "conformsTo"],
            "properties": {
              "@id": { "const": "ro-crate-metadata.json" },
              "@type": { "const": "CreativeWork" },
              "about": {
                "type": "object",
                "required": ["@id"],
                "properties": { "@id": { "const": "./" } },
                "additionalProperties": false
              },
              "conformsTo": {
                "type": "object",
                "required": ["@id"],
                "properties": { "@id": { "const": "https://w3id.org/ro/crate/1.3" } },
                "additionalProperties": false
              }
            }
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "required": ["@id", "@type", "identifier", "name", "description", "datePublished", "license", "about", "mentions", "conformsTo", "hasPart"],
            "properties": {
              "@id": { "const": "./" },
              "@type": { "const": "Dataset" },
              "identifier": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 },
              "datePublished": { "type": "string", "format": "date-time" },
              "license": { "$ref": "#/$defs/IdRef" },
              "about": { "$ref": "#/$defs/IdRef" },
              "mentions": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/IdRef" },
                "uniqueItems": true
              },
              "conformsTo": {
                "type": "array",
                "minItems": 2,
                "items": { "$ref": "#/$defs/IdRef" },
                "uniqueItems": true
              },
              "hasPart": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/IdRef" },
                "uniqueItems": true
              }
            }
          },
          "minContains": 1,
          "maxContains": 1
        }
      ]
    }
  },
  "$defs": {
    "IdRef": {
      "type": "object",
      "required": ["@id"],
      "properties": { "@id": { "type": "string", "minLength": 1 } },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
