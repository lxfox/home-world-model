{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homeworldmodel.org/spec/profiles/physical-asset-onboarding/v0.1/asset-onboarding-assessment.schema.json",
  "title": "HWM Asset Onboarding Assessment v0.1",
  "type": "object",
  "required": ["assessment_id", "bundle_ref", "purpose", "as_of", "required_axes", "axes", "overall_disposition", "limitations", "must_not_infer"],
  "properties": {
    "assessment_id": {"type": "string", "minLength": 1},
    "bundle_ref": {"type": "string", "minLength": 1},
    "purpose": {"type": "string", "minLength": 1},
    "as_of": {"type": "string", "format": "date-time"},
    "required_axes": {"type": "array", "minItems": 1, "items": {"enum": ["acquisition_trace", "receipt_and_quantity", "variant_alignment", "physical_asset_identity", "condition_acceptance", "installation_state", "function_position_binding", "endpoint_association", "commissioning_readiness", "operational_admission"]}, "uniqueItems": true},
    "axes": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "object", "required": ["status", "evidence_refs"], "properties": {"status": {"type": "string"}, "evidence_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}, "limitations": {"type": "array", "items": {"type": "string"}}}, "additionalProperties": false}},
    "overall_disposition": {"enum": ["onboarding_complete_for_declared_scope", "onboarding_partial", "quarantine_or_return", "not_applicable", "indeterminate"]},
    "relation_claim_candidates": {"type": "array", "items": {"type": "object", "required": ["relation_kind", "subject_ref", "object_ref", "valid_from"], "properties": {"relation_kind": {"enum": ["asset_instance_of_product_model", "asset_realizes_function_position", "asset_exposes_endpoint", "asset_replaces_asset"]}, "subject_ref": {"type": "string"}, "object_ref": {"type": "string"}, "valid_from": {"type": "string", "format": "date-time"}, "valid_through": {"type": ["string", "null"]}}, "additionalProperties": false}},
    "limitations": {"type": "array", "items": {"type": "string"}},
    "must_not_infer": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true}
  },
  "additionalProperties": false
}
