{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://homeworldmodel.org/spec/profiles/installed-influence-model/v0.1/installed-influence-model.schema.json",
  "title":"HWM Installed Influence Model v0.1",
  "type":"object",
  "required":["contract","contract_version","model_id","model_revision","previous_model_binding","identity_basis","semantic_kind","input_features","applicability_domain","output_specification","dataset_binding","training_procedure_binding","validation_report_binding","release_status","limitations","created_at","proof","extensions"],
  "properties":{
    "contract":{"const":"hwm-model:InstalledInfluenceModel"},"contract_version":{"const":"0.1.0"},"model_id":{"type":"string","minLength":1},"model_revision":{"type":"integer","minimum":1},"previous_model_binding":{"oneOf":[{"type":"null"},{"$ref":"#/$defs/Binding"}]},
    "identity_basis":{"type":"object","required":["household_id","installed_endpoint_binding","installation_geometry_binding","affected_feature_binding","affected_property","action_kind"],"properties":{"household_id":{"type":"string","minLength":1},"installed_endpoint_binding":{"$ref":"#/$defs/Binding"},"installation_geometry_binding":{"$ref":"#/$defs/Binding"},"affected_feature_binding":{"$ref":"#/$defs/Binding"},"affected_property":{"type":"string","minLength":1},"action_kind":{"type":"string","minLength":1}},"additionalProperties":false},
    "semantic_kind":{"enum":["predictive_association","causal_response"]},
    "input_features":{"type":"array","minItems":1,"items":{"type":"object","required":["feature_id","property","unit","role"],"properties":{"feature_id":{"type":"string","minLength":1},"property":{"type":"string","minLength":1},"unit":{"type":"string","minLength":1},"role":{"enum":["action_parameter","environment_context","prior_state","time_context"]}},"additionalProperties":false}},
    "applicability_domain":{"type":"object","required":["condition_claim_bindings","coverage_status","out_of_domain_behavior"],"properties":{"condition_claim_bindings":{"type":"array","uniqueItems":true,"items":{"$ref":"#/$defs/Binding"}},"coverage_status":{"enum":["bounded","partial","indeterminate"]},"out_of_domain_behavior":{"const":"indeterminate_no_extrapolation"}},"additionalProperties":false},
    "output_specification":{"type":"object","required":["property","unit","representation","uncertainty_representation"],"properties":{"property":{"type":"string","minLength":1},"unit":{"type":"string","minLength":1},"representation":{"enum":["point","interval","distribution","surface","other_declared"]},"uncertainty_representation":{"enum":["interval","distribution","quantiles","declared_metric_set"]}},"additionalProperties":false},
    "dataset_binding":{"$ref":"#/$defs/Binding"},"training_procedure_binding":{"$ref":"#/$defs/Binding"},"validation_report_binding":{"$ref":"#/$defs/Binding"},"release_status":{"enum":["candidate","validated","accepted_for_purpose","retired","contested"]},
    "limitations":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}},"created_at":{"type":"string","format":"date-time"},"proof":{"$ref":"#/$defs/Proof"},"extensions":{"type":"object"}
  },
  "$defs":{"Digest":{"type":"string","pattern":"^[0-9a-f]{64}$"},"Binding":{"type":"object","required":["artifact_id","revision","digest_algorithm","canonicalization","digest"],"properties":{"artifact_id":{"type":"string","minLength":1},"revision":{"type":"integer","minimum":1},"digest_algorithm":{"const":"sha-256"},"canonicalization":{"const":"RFC8785"},"digest":{"$ref":"#/$defs/Digest"}},"additionalProperties":false},"Proof":{"type":"object","required":["mode","verification_method","value"],"properties":{"mode":{"enum":["unsigned_fixture","jws","cose","vc"]},"verification_method":{"type":"string","minLength":1},"value":{"type":"string","minLength":1}},"additionalProperties":false}},
  "allOf":[{"if":{"properties":{"model_revision":{"const":1}}},"then":{"properties":{"previous_model_binding":{"type":"null"}}}},{"if":{"properties":{"model_revision":{"type":"integer","minimum":2}}},"then":{"properties":{"previous_model_binding":{"$ref":"#/$defs/Binding"}}}}],"additionalProperties":false
}
