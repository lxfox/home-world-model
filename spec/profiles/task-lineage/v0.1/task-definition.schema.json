{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homeworldmodel.org/spec/profiles/task-lineage/v0.1/task-definition.schema.json",
  "title": "HWM Task Lineage Definition v0.1",
  "type": "object",
  "required": ["contract", "contract_version", "task_id", "definition_revision", "previous_definition_binding", "identity_basis", "identity_basis_digest", "lineage", "created_at", "created_by_subject", "plan_bindings", "exit_criteria", "proof", "extensions"],
  "properties": {
    "contract": {"const": "hwm-task:Definition"},
    "contract_version": {"const": "0.1.0-fixture"},
    "task_id": {"type": "string", "minLength": 1},
    "definition_revision": {"type": "integer", "minimum": 1},
    "previous_definition_binding": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/DigestBinding"}]},
    "identity_basis": {"$ref": "#/$defs/IdentityBasis"},
    "identity_basis_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "lineage": {"$ref": "#/$defs/Lineage"},
    "created_at": {"type": "string", "format": "date-time"},
    "created_by_subject": {"type": "string", "minLength": 1},
    "plan_bindings": {"type": "array", "items": {"$ref": "#/$defs/DigestBinding"}},
    "exit_criteria": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/ExitCriterion"}},
    "proof": {"$ref": "#/$defs/Proof"},
    "extensions": {"type": "object", "additionalProperties": true}
  },
  "$defs": {
    "DigestBinding": {
      "type": "object",
      "required": ["artifact_id", "digest_algorithm", "canonicalization", "digest"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "digest_algorithm": {"const": "sha-256"},
        "canonicalization": {"const": "RFC8785"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "TaskBinding": {
      "type": "object",
      "required": ["task_id", "definition_revision", "digest_algorithm", "canonicalization", "digest"],
      "properties": {
        "task_id": {"type": "string", "minLength": 1},
        "definition_revision": {"type": "integer", "minimum": 1},
        "digest_algorithm": {"const": "sha-256"},
        "canonicalization": {"const": "RFC8785"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "IntentBinding": {
      "type": "object",
      "required": ["intent_id", "definition_revision", "digest_algorithm", "canonicalization", "digest"],
      "properties": {
        "intent_id": {"type": "string", "minLength": 1},
        "definition_revision": {"type": "integer", "minimum": 1},
        "digest_algorithm": {"const": "sha-256"},
        "canonicalization": {"const": "RFC8785"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "RoutineBinding": {
      "type": "object",
      "required": ["routine_id", "definition_revision", "digest_algorithm", "canonicalization", "digest"],
      "properties": {
        "routine_id": {"type": "string", "minLength": 1},
        "definition_revision": {"type": "integer", "minimum": 1},
        "digest_algorithm": {"const": "sha-256"},
        "canonicalization": {"const": "RFC8785"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "Occurrence": {
      "type": "object",
      "required": ["kind", "routine_binding", "occurrence_key", "original_scheduled_time"],
      "properties": {
        "kind": {"enum": ["one_off", "routine_occurrence"]},
        "routine_binding": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/RoutineBinding"}]},
        "occurrence_key": {"type": ["string", "null"], "minLength": 1},
        "original_scheduled_time": {"type": ["string", "null"], "format": "date-time"}
      },
      "allOf": [
        {
          "if": {"properties": {"kind": {"const": "one_off"}}, "required": ["kind"]},
          "then": {"properties": {"routine_binding": {"type": "null"}, "occurrence_key": {"type": "null"}, "original_scheduled_time": {"type": "null"}}},
          "else": {"properties": {"routine_binding": {"$ref": "#/$defs/RoutineBinding"}, "occurrence_key": {"type": "string"}, "original_scheduled_time": {"type": ["string", "null"]}}}
        }
      ],
      "additionalProperties": false
    },
    "IdentityBasis": {
      "type": "object",
      "required": ["household_id", "intent_binding", "purpose", "occurrence", "scope_refs"],
      "properties": {
        "household_id": {"type": "string", "minLength": 1},
        "intent_binding": {"$ref": "#/$defs/IntentBinding"},
        "purpose": {"type": "string", "minLength": 1},
        "occurrence": {"$ref": "#/$defs/Occurrence"},
        "scope_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    },
    "Lineage": {
      "type": "object",
      "required": ["relation", "source_task_bindings"],
      "properties": {
        "relation": {"enum": ["genesis", "split_child", "merge_result", "superseding"]},
        "source_task_bindings": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/TaskBinding"}}
      },
      "allOf": [
        {"if": {"properties": {"relation": {"const": "genesis"}}, "required": ["relation"]}, "then": {"properties": {"source_task_bindings": {"type": "array", "maxItems": 0}}}},
        {"if": {"properties": {"relation": {"enum": ["split_child", "superseding"]}}, "required": ["relation"]}, "then": {"properties": {"source_task_bindings": {"type": "array", "minItems": 1}}}},
        {"if": {"properties": {"relation": {"const": "merge_result"}}, "required": ["relation"]}, "then": {"properties": {"source_task_bindings": {"type": "array", "minItems": 2}}}}
      ],
      "additionalProperties": false
    },
    "ExitCriterion": {
      "type": "object",
      "required": ["criterion_id", "kind", "mandatory", "target_binding"],
      "properties": {
        "criterion_id": {"type": "string", "minLength": 1},
        "kind": {"enum": ["world_view_resolution", "goal_evaluation", "record_present", "proposal_terminal", "manual_acceptance"]},
        "mandatory": {"type": "boolean"},
        "target_binding": {"$ref": "#/$defs/DigestBinding"}
      },
      "additionalProperties": false
    },
    "Proof": {
      "type": "object",
      "required": ["mode", "verification_method", "value"],
      "properties": {
        "mode": {"enum": ["unsigned_fixture", "signature"]},
        "verification_method": {"type": "string", "minLength": 1},
        "value": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {"properties": {"definition_revision": {"const": 1}}, "required": ["definition_revision"]},
      "then": {"properties": {"previous_definition_binding": {"type": "null"}}},
      "else": {"properties": {"previous_definition_binding": {"$ref": "#/$defs/DigestBinding"}}}
    }
  ],
  "additionalProperties": false
}
