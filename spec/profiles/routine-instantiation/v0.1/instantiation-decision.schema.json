{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homeworldmodel.org/spec/profiles/routine-instantiation/v0.1/instantiation-decision.schema.json",
  "title": "HWM Routine Instantiation Decision v0.1",
  "type": "object",
  "required": ["contract", "contract_version", "decision_id", "routine_definition_binding", "routine_state_binding", "target_intent_state_binding", "occurrence", "materialization_key_digest", "evaluated_at", "as_of", "authority_epoch", "world_view_binding", "trigger_evidence_bindings", "condition_assessment_binding", "trigger_status", "condition_status", "lateness_status", "overlap_status", "deduplication_status", "decision_status", "task_definition_binding", "conflicting_task_bindings", "reason_codes", "proof", "extensions"],
  "properties": {
    "contract": {"const": "hwm-routine:InstantiationDecision"},
    "contract_version": {"const": "0.1.0-fixture"},
    "decision_id": {"type": "string", "minLength": 1},
    "routine_definition_binding": {"$ref": "#/$defs/RoutineBinding"},
    "routine_state_binding": {"$ref": "#/$defs/DigestBinding"},
    "target_intent_state_binding": {"$ref": "#/$defs/DigestBinding"},
    "occurrence": {"$ref": "#/$defs/Occurrence"},
    "materialization_key_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "evaluated_at": {"type": "string", "format": "date-time"},
    "as_of": {"type": "string", "format": "date-time"},
    "authority_epoch": {"type": "integer", "minimum": 0},
    "world_view_binding": {"$ref": "#/$defs/DigestBinding"},
    "trigger_evidence_bindings": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/DigestBinding"}},
    "condition_assessment_binding": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/DigestBinding"}]},
    "trigger_status": {"enum": ["matched", "not_matched", "indeterminate"]},
    "condition_status": {"enum": ["satisfied", "not_satisfied", "not_required", "indeterminate"]},
    "lateness_status": {"enum": ["on_time", "accepted_late", "expired", "not_applicable", "indeterminate"]},
    "overlap_status": {"enum": ["clear", "suppressed", "deferred", "not_applicable", "indeterminate"]},
    "deduplication_status": {"enum": ["new", "replay", "conflict", "not_evaluated", "indeterminate"]},
    "decision_status": {"enum": ["materialized", "not_eligible", "suppressed", "deferred", "duplicate", "expired", "integrity_conflict", "invalid", "indeterminate"]},
    "task_definition_binding": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/TaskBinding"}]},
    "conflicting_task_bindings": {"type": "array", "items": {"$ref": "#/$defs/TaskBinding"}},
    "reason_codes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "proof": {"$ref": "#/$defs/Proof"},
    "extensions": {"type": "object", "additionalProperties": true}
  },
  "$defs": {
    "DigestBinding": {
      "type": "object",
      "required": ["artifact_id", "digest_algorithm", "canonicalization", "digest"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "digest_algorithm": {"const": "sha-256"},
        "canonicalization": {"const": "RFC8785"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "RoutineBinding": {
      "type": "object",
      "required": ["routine_id", "definition_revision", "digest_algorithm", "canonicalization", "digest"],
      "properties": {
        "routine_id": {"type": "string", "minLength": 1},
        "definition_revision": {"type": "integer", "minimum": 1},
        "digest_algorithm": {"const": "sha-256"},
        "canonicalization": {"const": "RFC8785"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "TaskBinding": {
      "type": "object",
      "required": ["task_id", "definition_revision", "digest_algorithm", "canonicalization", "digest"],
      "properties": {
        "task_id": {"type": "string", "minLength": 1},
        "definition_revision": {"type": "integer", "minimum": 1},
        "digest_algorithm": {"const": "sha-256"},
        "canonicalization": {"const": "RFC8785"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "Occurrence": {
      "type": "object",
      "required": ["kind", "occurrence_key", "original_local_time", "time_zone", "nominal_instant", "trigger_time"],
      "properties": {
        "kind": {"enum": ["temporal", "event_driven"]},
        "occurrence_key": {"type": "string", "minLength": 1},
        "original_local_time": {"type": ["string", "null"], "minLength": 1},
        "time_zone": {"type": ["string", "null"], "minLength": 1},
        "nominal_instant": {"type": ["string", "null"], "format": "date-time"},
        "trigger_time": {"type": "string", "format": "date-time"}
      },
      "allOf": [
        {
          "if": {"type": "object", "properties": {"kind": {"const": "temporal"}}, "required": ["kind"]},
          "then": {"type": "object", "properties": {"original_local_time": {"type": "string"}, "time_zone": {"type": "string"}, "nominal_instant": {"type": "string"}}},
          "else": {"type": "object", "properties": {"original_local_time": {"type": "null"}, "time_zone": {"type": "null"}, "nominal_instant": {"type": "null"}}}
        }
      ],
      "additionalProperties": false
    },
    "Proof": {
      "type": "object",
      "required": ["mode", "verification_method", "value"],
      "properties": {
        "mode": {"enum": ["unsigned_fixture", "signature"]},
        "verification_method": {"type": "string", "minLength": 1},
        "value": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
