{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homeworldmodel.org/spec/profiles/task-lineage/v0.1/task-state.schema.json",
  "title": "HWM Task State Assessment v0.1",
  "type": "object",
  "required": ["contract", "contract_version", "state_id", "task_id", "state_revision", "previous_state_binding", "task_definition_binding", "assessed_at", "as_of", "authority_epoch", "lifecycle_status", "criterion_results", "open_attempt_bindings", "terminal", "reopen", "proof", "extensions"],
  "properties": {
    "contract": {"const": "hwm-task:StateAssessment"},
    "contract_version": {"const": "0.1.0-fixture"},
    "state_id": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "state_revision": {"type": "integer", "minimum": 1},
    "previous_state_binding": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/DigestBinding"}]},
    "task_definition_binding": {"$ref": "#/$defs/TaskBinding"},
    "assessed_at": {"type": "string", "format": "date-time"},
    "as_of": {"type": "string", "format": "date-time"},
    "authority_epoch": {"type": "integer", "minimum": 0},
    "lifecycle_status": {"enum": ["not_started", "active", "waiting", "blocked", "completed", "failed", "cancelled", "superseded", "split", "merged", "indeterminate"]},
    "criterion_results": {"type": "array", "items": {"$ref": "#/$defs/CriterionResult"}},
    "open_attempt_bindings": {"type": "array", "items": {"$ref": "#/$defs/DigestBinding"}},
    "terminal": {"$ref": "#/$defs/Terminal"},
    "reopen": {"$ref": "#/$defs/Reopen"},
    "proof": {"$ref": "#/$defs/Proof"},
    "extensions": {"type": "object", "additionalProperties": true}
  },
  "$defs": {
    "DigestBinding": {
      "type": "object",
      "required": ["artifact_id", "digest_algorithm", "canonicalization", "digest"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "digest_algorithm": {"const": "sha-256"},
        "canonicalization": {"const": "RFC8785"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "TaskBinding": {
      "type": "object",
      "required": ["task_id", "definition_revision", "digest_algorithm", "canonicalization", "digest"],
      "properties": {
        "task_id": {"type": "string", "minLength": 1},
        "definition_revision": {"type": "integer", "minimum": 1},
        "digest_algorithm": {"const": "sha-256"},
        "canonicalization": {"const": "RFC8785"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "CriterionResult": {
      "type": "object",
      "required": ["criterion_id", "result", "evidence_bindings"],
      "properties": {
        "criterion_id": {"type": "string", "minLength": 1},
        "result": {"enum": ["satisfied", "unsatisfied", "indeterminate", "not_due"]},
        "evidence_bindings": {"type": "array", "items": {"$ref": "#/$defs/DigestBinding"}}
      },
      "additionalProperties": false
    },
    "Terminal": {
      "type": "object",
      "required": ["kind", "transition_record_binding", "authority_decision_binding", "related_task_bindings"],
      "properties": {
        "kind": {"enum": ["not_applicable", "completed", "failed", "cancelled", "superseded", "split", "merged"]},
        "transition_record_binding": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/DigestBinding"}]},
        "authority_decision_binding": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/DigestBinding"}]},
        "related_task_bindings": {"type": "array", "items": {"$ref": "#/$defs/TaskBinding"}}
      },
      "additionalProperties": false
    },
    "Reopen": {
      "type": "object",
      "required": ["prior_terminal_state_binding", "authority_decision_binding"],
      "properties": {
        "prior_terminal_state_binding": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/DigestBinding"}]},
        "authority_decision_binding": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/DigestBinding"}]}
      },
      "additionalProperties": false
    },
    "Proof": {
      "type": "object",
      "required": ["mode", "verification_method", "value"],
      "properties": {
        "mode": {"enum": ["unsigned_fixture", "signature"]},
        "verification_method": {"type": "string", "minLength": 1},
        "value": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {"properties": {"state_revision": {"const": 1}}, "required": ["state_revision"]},
      "then": {"properties": {"previous_state_binding": {"type": "null"}}},
      "else": {"properties": {"previous_state_binding": {"$ref": "#/$defs/DigestBinding"}}}
    }
  ],
  "additionalProperties": false
}
