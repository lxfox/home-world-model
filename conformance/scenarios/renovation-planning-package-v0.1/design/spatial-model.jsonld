{
  "@context": {
    "bot": "https://w3id.org/bot#",
    "sosa": "http://www.w3.org/ns/sosa/",
    "name": "https://schema.org/name"
  },
  "@graph": [
    {
      "@id": "urn:hwm:building:renovation-fixture",
      "@type": "bot:Building",
      "name": "Synthetic apartment design",
      "bot:hasSpace": { "@id": "urn:hwm:space:planned-bedroom" }
    },
    {
      "@id": "urn:hwm:space:planned-bedroom",
      "@type": "bot:Space",
      "name": "Planned bedroom",
      "bot:containsZone": { "@id": "urn:hwm:zone:planned-reading" },
      "bot:hasSimple3DModel": "BOX(0 0 0,4.2 3.6 2.8)"
    },
    {
      "@id": "urn:hwm:zone:planned-reading",
      "@type": ["bot:Zone", "sosa:FeatureOfInterest"],
      "name": "Planned reading measurement zone",
      "bot:hasSimple3DModel": "BOX(0.5 0.7 0.72,1.3 1.3 0.82)"
    }
  ]
}
