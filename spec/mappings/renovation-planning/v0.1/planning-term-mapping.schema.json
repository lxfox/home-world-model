{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homeworldmodel.org/spec/mappings/renovation-planning/v0.1/planning-term-mapping.schema.json",
  "title": "HWM Renovation Planning term mapping audit v0.1",
  "type": "object",
  "required": ["artifact", "version", "status", "normative_language", "sources", "terms"],
  "properties": {
    "artifact": { "const": "hwm:RenovationPlanningTermMappingAudit" },
    "version": { "const": "0.1.0" },
    "status": { "const": "mapping_candidate" },
    "normative_language": { "const": "en" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_id", "title", "url", "version_or_date", "maturity"],
        "properties": {
          "source_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" },
          "version_or_date": { "type": "string", "minLength": 1 },
          "maturity": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "terms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["term_id", "layer", "decision", "external_terms", "residual_gap", "normative_action", "publication_rule", "confidence", "fixture_evidence"],
        "properties": {
          "term_id": { "type": "string", "minLength": 1 },
          "layer": { "enum": ["domain_role", "relationship", "wire_field", "behavioral_boundary"] },
          "decision": { "enum": ["external_reuse", "hwm_application_profile", "provisional_pending_mapping", "do_not_standardize"] },
          "external_terms": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["source_id", "term", "uri", "coverage"],
              "properties": {
                "source_id": { "type": "string", "minLength": 1 },
                "term": { "type": "string", "minLength": 1 },
                "uri": { "type": "string", "format": "uri" },
                "coverage": { "enum": ["exact", "strong_partial", "partial", "binding_specific"] }
              },
              "additionalProperties": false
            }
          },
          "residual_gap": { "type": "string", "minLength": 1 },
          "normative_action": { "enum": ["remove_hwm_vocabulary", "retain_profile_constraint", "retain_wire_only", "defer_claim_of_novelty", "reject_term"] },
          "publication_rule": { "type": "string", "minLength": 1 },
          "confidence": { "enum": ["high", "medium", "low"] },
          "fixture_evidence": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
