{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://homeworldmodel.org/spec/profiles/plan-materialization/v0.1/plan-materialization-assessment.schema.json",
  "title":"HWM Plan Materialization Assessment v0.1",
  "type":"object",
  "required":["contract","contract_version","assessment_id","household_id","purpose","assessed_at","as_of","authority_epoch","intent_binding","routing_assessment_binding","world_view_binding","policy_claim_binding","policy_resolution","reliance_factors","proposal_self_containment_status","result","reason_codes","proof","extensions"],
  "properties":{
    "contract":{"const":"hwm-plan:MaterializationAssessment"},"contract_version":{"const":"0.1.0-fixture"},
    "assessment_id":{"type":"string","minLength":1},"household_id":{"type":"string","minLength":1},"purpose":{"type":"string","minLength":1},
    "assessed_at":{"type":"string","format":"date-time"},"as_of":{"type":"string","format":"date-time"},"authority_epoch":{"type":"integer","minimum":0},
    "intent_binding":{"$ref":"#/$defs/Binding"},"routing_assessment_binding":{"$ref":"#/$defs/Binding"},"world_view_binding":{"$ref":"#/$defs/Binding"},"policy_claim_binding":{"$ref":"#/$defs/Binding"},
    "policy_resolution":{"$ref":"#/$defs/Resolution"},
    "reliance_factors":{"$ref":"#/$defs/Reliance"},
    "proposal_self_containment_status":{"enum":["complete","incomplete","not_evaluated","indeterminate"]},
    "result":{"enum":["plan_artifact_required","proposal_self_contained","indeterminate"]},
    "reason_codes":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}},"proof":{"$ref":"#/$defs/Proof"},"extensions":{"type":"object","additionalProperties":true}
  },
  "allOf":[
    {"if":{"properties":{"result":{"enum":["plan_artifact_required","proposal_self_contained"]}}},"then":{"properties":{"policy_resolution":{"$ref":"#/$defs/Qualified"}}}},
    {"if":{"properties":{"result":{"const":"proposal_self_contained"}}},"then":{"properties":{"proposal_self_containment_status":{"const":"complete"},"reliance_factors":{"$ref":"#/$defs/NoReliance"}}}}
  ],
  "$defs":{
    "Binding":{"type":"object","required":["artifact_id","content_scope","digest_algorithm","canonicalization","digest"],"properties":{"artifact_id":{"type":"string","minLength":1},"content_scope":{"enum":["artifact","claim_body"]},"digest_algorithm":{"const":"sha-256"},"canonicalization":{"const":"RFC8785"},"digest":{"type":"string","pattern":"^[0-9a-f]{64}$"}},"additionalProperties":false},
    "Resolution":{"type":"object","required":["resolution_id","availability_status","epistemic_status","freshness_status","temporal_status"],"properties":{"resolution_id":{"type":"string","minLength":1},"availability_status":{"enum":["available","not_observed","source_unavailable","access_denied"]},"epistemic_status":{"enum":["accepted","contested","unknown","not_verified","not_evaluated"]},"freshness_status":{"enum":["current","stale","not_applicable","unknown"]},"temporal_status":{"enum":["in_effect","not_yet_in_effect","expired","unbounded","mixed","indeterminate"]}},"additionalProperties":false},
    "Qualified":{"allOf":[{"$ref":"#/$defs/Resolution"},{"type":"object","properties":{"availability_status":{"const":"available"},"epistemic_status":{"const":"accepted"},"freshness_status":{"enum":["current","not_applicable"]},"temporal_status":{"enum":["in_effect","unbounded"]}}}]},
    "Reliance":{"type":"object","required":["cross_proposal_dependencies","handoff_or_continuity","household_alternative_selection","authority_or_professional_method_review","long_lived_assumptions","cross_proposal_contingency","task_method_continuity","explicit_plan_reference","policy_audit"],"properties":{"cross_proposal_dependencies":{"enum":["not_required","required","indeterminate"]},"handoff_or_continuity":{"enum":["not_required","required","indeterminate"]},"household_alternative_selection":{"enum":["not_required","required","indeterminate"]},"authority_or_professional_method_review":{"enum":["not_required","required","indeterminate"]},"long_lived_assumptions":{"enum":["not_required","required","indeterminate"]},"cross_proposal_contingency":{"enum":["not_required","required","indeterminate"]},"task_method_continuity":{"enum":["not_required","required","indeterminate"]},"explicit_plan_reference":{"enum":["not_required","required","indeterminate"]},"policy_audit":{"enum":["not_required","required","indeterminate"]}},"additionalProperties":false},
    "NoReliance":{"allOf":[{"$ref":"#/$defs/Reliance"},{"type":"object","properties":{"cross_proposal_dependencies":{"const":"not_required"},"handoff_or_continuity":{"const":"not_required"},"household_alternative_selection":{"const":"not_required"},"authority_or_professional_method_review":{"const":"not_required"},"long_lived_assumptions":{"const":"not_required"},"cross_proposal_contingency":{"const":"not_required"},"task_method_continuity":{"const":"not_required"},"explicit_plan_reference":{"const":"not_required"},"policy_audit":{"const":"not_required"}}}]},
    "Proof":{"type":"object","required":["mode","verification_method","value"],"properties":{"mode":{"enum":["unsigned_fixture","jws","cose","vc"]},"verification_method":{"type":"string","minLength":1},"value":{"type":"string","minLength":1}},"additionalProperties":false}
  },"additionalProperties":false
}
