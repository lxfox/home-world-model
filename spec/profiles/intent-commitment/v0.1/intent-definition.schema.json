{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homeworldmodel.org/spec/profiles/intent-commitment/v0.1/intent-definition.schema.json",
  "title": "HWM Intent Definition v0.1",
  "type": "object",
  "required": ["contract", "contract_version", "intent_id", "definition_revision", "previous_definition_binding", "identity_basis", "identity_basis_digest", "expectations", "basis_bindings", "revision", "created_at", "created_by_subject", "proof", "extensions"],
  "properties": {
    "contract": {"const": "hwm-intent:Definition"},
    "contract_version": {"const": "0.1.0-fixture"},
    "intent_id": {"type": "string", "minLength": 1},
    "definition_revision": {"type": "integer", "minimum": 1},
    "previous_definition_binding": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/DigestBinding"}]},
    "identity_basis": {"$ref": "#/$defs/IdentityBasis"},
    "identity_basis_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "expectations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/Expectation"}},
    "basis_bindings": {"type": "array", "items": {"$ref": "#/$defs/DigestBinding"}},
    "revision": {"$ref": "#/$defs/Revision"},
    "created_at": {"type": "string", "format": "date-time"},
    "created_by_subject": {"type": "string", "minLength": 1},
    "proof": {"$ref": "#/$defs/Proof"},
    "extensions": {"type": "object", "additionalProperties": true}
  },
  "$defs": {
    "DigestBinding": {
      "type": "object",
      "required": ["artifact_id", "digest_algorithm", "canonicalization", "digest"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "digest_algorithm": {"const": "sha-256"},
        "canonicalization": {"const": "RFC8785"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "IdentityBasis": {
      "type": "object",
      "required": ["household_id", "purpose", "lifecycle_kind", "beneficiary_refs", "scope_refs"],
      "properties": {
        "household_id": {"type": "string", "minLength": 1},
        "purpose": {"type": "string", "minLength": 1},
        "lifecycle_kind": {"enum": ["transient", "persistent"]},
        "beneficiary_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "scope_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    },
    "Expectation": {
      "type": "object",
      "required": ["expectation_id", "kind", "mandatory", "target_binding"],
      "properties": {
        "expectation_id": {"type": "string", "minLength": 1},
        "kind": {"enum": ["goal", "requirement", "constraint"]},
        "mandatory": {"type": "boolean"},
        "target_binding": {"$ref": "#/$defs/DigestBinding"}
      },
      "additionalProperties": false
    },
    "ExpectationLineage": {
      "type": "object",
      "required": ["previous_expectation_id", "current_expectation_id", "relation"],
      "properties": {
        "previous_expectation_id": {"type": ["string", "null"], "minLength": 1},
        "current_expectation_id": {"type": ["string", "null"], "minLength": 1},
        "relation": {"enum": ["preserved", "refined", "relaxed", "corrected", "added", "removed"]}
      },
      "allOf": [
        {"if": {"properties": {"relation": {"const": "added"}}, "required": ["relation"]}, "then": {"properties": {"previous_expectation_id": {"type": "null"}, "current_expectation_id": {"type": "string"}}}},
        {"if": {"properties": {"relation": {"const": "removed"}}, "required": ["relation"]}, "then": {"properties": {"previous_expectation_id": {"type": "string"}, "current_expectation_id": {"type": "null"}}}},
        {"if": {"properties": {"relation": {"enum": ["preserved", "refined", "relaxed", "corrected"]}}, "required": ["relation"]}, "then": {"properties": {"previous_expectation_id": {"type": "string"}, "current_expectation_id": {"type": "string"}}}}
      ],
      "additionalProperties": false
    },
    "Revision": {
      "type": "object",
      "required": ["relation", "continuity_decision_binding", "expectation_lineage"],
      "properties": {
        "relation": {"enum": ["genesis", "refinement", "relaxation", "correction", "restatement"]},
        "continuity_decision_binding": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/DigestBinding"}]},
        "expectation_lineage": {"type": "array", "items": {"$ref": "#/$defs/ExpectationLineage"}}
      },
      "additionalProperties": false
    },
    "Proof": {
      "type": "object",
      "required": ["mode", "verification_method", "value"],
      "properties": {
        "mode": {"enum": ["unsigned_fixture", "signature"]},
        "verification_method": {"type": "string", "minLength": 1},
        "value": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {"properties": {"definition_revision": {"const": 1}}, "required": ["definition_revision"]},
      "then": {"properties": {"previous_definition_binding": {"type": "null"}, "revision": {"type": "object", "properties": {"relation": {"const": "genesis"}, "continuity_decision_binding": {"type": "null"}, "expectation_lineage": {"type": "array", "maxItems": 0}}, "required": ["relation", "continuity_decision_binding", "expectation_lineage"]}}},
      "else": {"properties": {"previous_definition_binding": {"$ref": "#/$defs/DigestBinding"}, "revision": {"type": "object", "properties": {"relation": {"enum": ["refinement", "relaxation", "correction", "restatement"]}, "continuity_decision_binding": {"$ref": "#/$defs/DigestBinding"}, "expectation_lineage": {"type": "array", "minItems": 1}}, "required": ["relation", "continuity_decision_binding", "expectation_lineage"]}}}
    }
  ],
  "additionalProperties": false
}
