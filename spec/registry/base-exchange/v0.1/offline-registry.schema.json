{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://homeworldmodel.org/spec/registry/base-exchange/v0.1/offline-registry.schema.json",
  "title":"HWM Base Exchange Offline Registry v0.1",
  "type":"object",
  "required":["registry_id","version","conformance_set_ref","entries"],
  "properties":{
    "registry_id":{"const":"https://homeworldmodel.org/spec/registry/base-exchange/v0.1"},
    "version":{"const":"0.1.0"},
    "conformance_set_ref":{"type":"string","pattern":"^sha256:[0-9a-f]{64}$"},
    "entries":{"type":"array","minItems":1,"items":{"type":"object","required":["uri","path","media_type","role","size","sha256"],"properties":{"uri":{"type":"string","format":"uri"},"path":{"type":"string","minLength":1},"media_type":{"enum":["text/markdown","application/schema+json","application/json"]},"role":{"enum":["normative_document","json_schema","profile_descriptor","conformance_set","composition_assessment"]},"size":{"type":"integer","minimum":1},"sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"}},"additionalProperties":false}}
  },
  "additionalProperties":false
}
