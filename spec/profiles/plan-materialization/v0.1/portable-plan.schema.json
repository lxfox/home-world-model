{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://homeworldmodel.org/spec/profiles/plan-materialization/v0.1/portable-plan.schema.json",
  "title":"HWM Portable Plan v0.1","type":"object",
  "required":["contract","contract_version","plan_id","plan_revision","previous_plan_binding","household_id","purpose","intent_binding","task_binding","routing_assessment_binding","materialization_assessment_binding","based_on_world_view_binding","realization_scope_refs","decision_input_bindings","assumption_bindings","steps","alternatives","checkpoint_bindings","contingency_bindings","created_at","created_by_subject","proof","extensions"],
  "properties":{
    "contract":{"const":"hwm-plan:PortablePlan"},"contract_version":{"const":"0.1.0-fixture"},"plan_id":{"type":"string","minLength":1},"plan_revision":{"type":"integer","minimum":1},
    "previous_plan_binding":{"oneOf":[{"type":"null"},{"$ref":"#/$defs/Binding"}]},"household_id":{"type":"string","minLength":1},"purpose":{"type":"string","minLength":1},
    "intent_binding":{"$ref":"#/$defs/Binding"},"task_binding":{"oneOf":[{"type":"null"},{"$ref":"#/$defs/Binding"}]},"routing_assessment_binding":{"$ref":"#/$defs/Binding"},"materialization_assessment_binding":{"$ref":"#/$defs/Binding"},"based_on_world_view_binding":{"$ref":"#/$defs/Binding"},
    "realization_scope_refs":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}},"decision_input_bindings":{"type":"array","minItems":1,"uniqueItems":true,"items":{"$ref":"#/$defs/Binding"}},"assumption_bindings":{"type":"array","uniqueItems":true,"items":{"$ref":"#/$defs/Binding"}},
    "steps":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/Step"}},"alternatives":{"type":"array","items":{"$ref":"#/$defs/Alternative"}},"checkpoint_bindings":{"type":"array","uniqueItems":true,"items":{"$ref":"#/$defs/Binding"}},"contingency_bindings":{"type":"array","uniqueItems":true,"items":{"$ref":"#/$defs/Binding"}},
    "created_at":{"type":"string","format":"date-time"},"created_by_subject":{"type":"string","minLength":1},"proof":{"$ref":"#/$defs/Proof"},"extensions":{"type":"object","additionalProperties":true}
  },
  "allOf":[{"if":{"properties":{"plan_revision":{"const":1}}},"then":{"properties":{"previous_plan_binding":{"type":"null"}}},"else":{"properties":{"previous_plan_binding":{"$ref":"#/$defs/Binding"}}}}],
  "$defs":{
    "Binding":{"type":"object","required":["artifact_id","content_scope","digest_algorithm","canonicalization","digest"],"properties":{"artifact_id":{"type":"string","minLength":1},"content_scope":{"enum":["artifact","claim_body"]},"digest_algorithm":{"const":"sha-256"},"canonicalization":{"const":"RFC8785"},"digest":{"type":"string","pattern":"^[0-9a-f]{64}$"}},"additionalProperties":false},
    "Step":{"type":"object","required":["step_id","kind","depends_on_step_ids","artifact_binding","outcome_gate_binding","reason_codes"],"properties":{"step_id":{"type":"string","minLength":1},"kind":{"enum":["proposal_candidate","observation_checkpoint","deliberation_checkpoint","external_dependency","task_transition"]},"depends_on_step_ids":{"type":"array","uniqueItems":true,"items":{"type":"string","minLength":1}},"artifact_binding":{"oneOf":[{"type":"null"},{"$ref":"#/$defs/Binding"}]},"outcome_gate_binding":{"oneOf":[{"type":"null"},{"$ref":"#/$defs/Binding"}]},"reason_codes":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}}},"additionalProperties":false},
    "Alternative":{"type":"object","required":["alternative_id","disposition","basis_bindings","reason_codes"],"properties":{"alternative_id":{"type":"string","minLength":1},"disposition":{"enum":["selected","not_selected","deferred"]},"basis_bindings":{"type":"array","uniqueItems":true,"items":{"$ref":"#/$defs/Binding"}},"reason_codes":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}}},"additionalProperties":false},
    "Proof":{"type":"object","required":["mode","verification_method","value"],"properties":{"mode":{"enum":["unsigned_fixture","jws","cose","vc"]},"verification_method":{"type":"string","minLength":1},"value":{"type":"string","minLength":1}},"additionalProperties":false}
  },"additionalProperties":false
}
