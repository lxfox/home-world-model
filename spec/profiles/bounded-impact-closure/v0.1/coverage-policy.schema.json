{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homeworldmodel.org/spec/profiles/bounded-impact-closure/v0.1/coverage-policy.schema.json",
  "title": "HWM Bounded Impact Closure Coverage Policy v0.1",
  "type": "object",
  "required": ["contract", "contract_version", "document_id", "household_id", "authority_id", "authority_epoch", "issued_at", "policy_combining_strategy", "coverage_rules", "proof", "extensions"],
  "properties": {
    "contract": { "const": "hwm-impact:CoveragePolicyDocument" },
    "contract_version": { "const": "0.1.0-fixture" },
    "document_id": { "type": "string", "minLength": 1 },
    "household_id": { "type": "string", "minLength": 1 },
    "authority_id": { "type": "string", "minLength": 1 },
    "authority_epoch": { "type": "integer", "minimum": 0 },
    "issued_at": { "type": "string", "format": "date-time" },
    "policy_combining_strategy": { "const": "only_one_applicable" },
    "coverage_rules": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/CoverageRule" } },
    "proof": { "$ref": "#/$defs/Proof" },
    "extensions": { "type": "object", "additionalProperties": true }
  },
  "$defs": {
    "NonEmptyUniqueStrings": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "ScopeSelector": {
      "type": "object",
      "required": ["mode", "values"],
      "properties": {
        "mode": { "enum": ["all", "listed"] },
        "values": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      },
      "allOf": [
        { "if": { "properties": { "mode": { "const": "all" } } }, "then": { "properties": { "values": { "type": "array", "maxItems": 0 } } } },
        { "if": { "properties": { "mode": { "const": "listed" } } }, "then": { "properties": { "values": { "type": "array", "minItems": 1 } } } }
      ],
      "additionalProperties": false
    },
    "Validity": {
      "type": "object", "required": ["from", "to"],
      "properties": { "from": { "type": "string", "format": "date-time" }, "to": { "type": "string", "format": "date-time" } },
      "additionalProperties": false
    },
    "ImpactChannel": {
      "type": "object",
      "required": ["channel_id", "procedure_id", "maximum_report_age_seconds", "extensions"],
      "properties": {
        "channel_id": { "type": "string", "minLength": 1 },
        "procedure_id": { "type": "string", "minLength": 1 },
        "maximum_report_age_seconds": { "type": "integer", "minimum": 1 },
        "extensions": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": false
    },
    "CoverageRule": {
      "type": "object",
      "required": ["rule_id", "action_types", "purposes", "effect_domains", "space_scope", "risk_levels", "maximum_horizon_seconds", "required_channels", "validity", "extensions"],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "action_types": { "$ref": "#/$defs/NonEmptyUniqueStrings" },
        "purposes": { "$ref": "#/$defs/NonEmptyUniqueStrings" },
        "effect_domains": { "$ref": "#/$defs/NonEmptyUniqueStrings" },
        "space_scope": { "$ref": "#/$defs/ScopeSelector" },
        "risk_levels": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["low", "moderate", "high", "emergency"] } },
        "maximum_horizon_seconds": { "type": "integer", "minimum": 1 },
        "required_channels": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ImpactChannel" } },
        "validity": { "$ref": "#/$defs/Validity" },
        "extensions": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": false
    },
    "Proof": {
      "type": "object", "required": ["mode", "verification_method"],
      "properties": { "mode": { "enum": ["unsigned_fixture", "digest", "signature", "vc"] }, "verification_method": { "type": "string", "minLength": 1 }, "value": { "type": "string" } },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
