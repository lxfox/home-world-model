{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://homeworldmodel.org/spec/profiles/entity-identity-alignment/v0.1/identity-alignment-request.schema.json",
  "title":"HWM Identity Alignment Request v0.1",
  "type":"object",
  "required":["contract","contract_version","request_id","household_id","left_entity_ref","right_entity_ref","left_kind","right_kind","purpose","as_of","required_strength","accepted_namespaces","policy_digest","authority_epoch","intended_consequences","proof","extensions"],
  "properties":{
    "contract":{"const":"hwm-identity:AlignmentRequest"},"contract_version":{"const":"0.1.0"},
    "request_id":{"type":"string","minLength":1},"household_id":{"type":"string","minLength":1},
    "left_entity_ref":{"type":"string","minLength":1},"right_entity_ref":{"type":"string","minLength":1},
    "left_kind":{"$ref":"#/$defs/Kind"},"right_kind":{"$ref":"#/$defs/Kind"},
    "purpose":{"type":"string","minLength":1},"as_of":{"type":"string","format":"date-time"},
    "required_strength":{"enum":["tentative_candidate","operational_reference","safety_critical_reference"]},
    "accepted_namespaces":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}},
    "policy_digest":{"$ref":"#/$defs/Digest"},"authority_epoch":{"type":"integer","minimum":0},
    "intended_consequences":{"type":"array","minItems":1,"uniqueItems":true,"items":{"enum":["evaluate_identity_only","propose_typed_relation_claim","qualify_reference_for_declared_use","trigger_dependency_revalidation"]}},
    "proof":{"$ref":"#/$defs/Proof"},"extensions":{"type":"object"}
  },
  "$defs":{
    "Digest":{"type":"string","pattern":"^[0-9a-f]{64}$"},
    "Kind":{"enum":["physical_asset","function_position","product_model","digital_endpoint","space","spatial_representation","authority_subject","pet_subject","observation_track"]},
    "Proof":{"type":"object","required":["mode","verification_method","value"],"properties":{"mode":{"enum":["unsigned_fixture","jws","cose","vc"]},"verification_method":{"type":"string","minLength":1},"value":{"type":"string","minLength":1}},"additionalProperties":false}
  },
  "additionalProperties":false
}
