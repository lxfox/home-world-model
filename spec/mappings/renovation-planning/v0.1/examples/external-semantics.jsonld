    },
    {
      "@id": "urn:hwm:activity:evaluate-option-b",
      "@type": "prov:Activity",
      "prov:used": [
        { "@id": "urn:hwm:claim:planned-option-b-simulated-effect" },
        { "@id": "urn:hwm:claim:planned-reading-requirement" }
