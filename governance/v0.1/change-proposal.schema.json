{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://homeworldmodel.org/governance/v0.1/change-proposal.schema.json",
  "title":"HWM Specification Change Proposal",
  "type":"object",
  "required":["proposal_id","revision","title","normative_delta","affected_artifacts","compatibility_claim","known_tradeoffs"],
  "properties":{
    "proposal_id":{"type":"string","minLength":1},
    "revision":{"type":"integer","minimum":1},
    "title":{"type":"string","minLength":1},
    "normative_delta":{"type":"string","minLength":1},
    "affected_artifacts":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1,"pattern":"^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"}},
    "compatibility_claim":{"type":"string","minLength":1},
    "known_tradeoffs":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}}
  },
  "additionalProperties":false
}
