{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homeworldmodel.org/spec/profiles/interactive-evidence/v0.1/interactive-evidence-binding.schema.json",
  "title": "HWM Interactive Evidence Binding v0.1",
  "type": "object",
  "required": ["contract", "contract_version", "challenge_id", "episode_id", "requester", "purpose", "authority_epoch", "target", "question", "evidence", "extensions"],
  "properties": {
    "contract": {"const": "hwm:InteractiveEvidenceBinding"},
    "contract_version": {"const": "0.1.0-fixture"},
    "challenge_id": {"type": "string", "format": "uri", "minLength": 1},
    "episode_id": {"type": "string", "format": "uri", "minLength": 1},
    "requester": {"type": "string", "format": "uri", "minLength": 1},
    "purpose": {"type": "string", "format": "uri", "minLength": 1},
    "authority_epoch": {"type": "integer", "minimum": 0},
    "target": {
      "type": "object",
      "required": ["claim_id", "proposition_digest", "scope"],
      "properties": {
        "claim_id": {"type": "string", "format": "uri", "minLength": 1},
        "proposition_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "scope": {
          "type": "object",
          "required": ["subject", "predicate", "competence_ceiling"],
          "properties": {
            "subject": {"type": "string", "format": "uri", "minLength": 1},
            "predicate": {"type": "string", "minLength": 1},
            "competence_ceiling": {"type": "string", "minLength": 1}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "question": {
      "type": "object",
      "required": ["record_id", "presented_text", "response_options"],
      "properties": {
        "record_id": {"type": "string", "format": "uri", "minLength": 1},
        "presented_text": {"type": "string", "minLength": 1},
        "response_options": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "required": ["value", "meaning"],
            "properties": {
              "value": {"type": "string", "minLength": 1},
              "meaning": {"enum": ["confirms", "refutes", "corrects", "cannot_tell"]}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "response": {
      "type": "object",
      "required": ["record_id", "attributed_to", "recorded_at", "selected_value", "meaning"],
      "properties": {
        "record_id": {"type": "string", "format": "uri", "minLength": 1},
        "attributed_to": {"type": "string", "format": "uri", "minLength": 1},
        "recorded_at": {"type": "string", "format": "date-time"},
        "selected_value": {"type": "string", "minLength": 1},
        "meaning": {"enum": ["confirms", "refutes", "corrects", "cannot_tell"]}
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["origin_ids", "observation_record_ids", "action_trace_ids"],
      "properties": {
        "origin_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "format": "uri"}},
        "observation_record_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "format": "uri"}},
        "action_trace_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "format": "uri"}}
      },
      "additionalProperties": false
    },
    "extensions": {"type": "object"}
  },
  "additionalProperties": false
}
