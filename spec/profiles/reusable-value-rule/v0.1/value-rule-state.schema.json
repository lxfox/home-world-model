{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://homeworldmodel.org/spec/profiles/reusable-value-rule/v0.1/value-rule-state.schema.json",
  "title":"HWM Value Rule State v0.1",
  "type":"object",
  "required":["contract","contract_version","state_id","state_revision","previous_state_binding","definition_binding","authority_decision_binding","authority_epoch","status","as_of","effective_at","recorded_at","proof","extensions"],
  "properties":{
    "contract":{"const":"hwm-value-rule:State"},
    "contract_version":{"const":"0.1.0"},
    "state_id":{"type":"string","minLength":1},
    "state_revision":{"type":"integer","minimum":1},
    "previous_state_binding":{"oneOf":[{"type":"null"},{"$ref":"#/$defs/Binding"}]},
    "definition_binding":{"$ref":"#/$defs/Binding"},
    "authority_decision_binding":{"$ref":"#/$defs/Binding"},
    "authority_epoch":{"type":"integer","minimum":0},
    "status":{"enum":["proposed","active","paused","retired","superseded","contested","indeterminate"]},
    "successor_definition_binding":{"$ref":"#/$defs/Binding"},
    "as_of":{"type":"string","format":"date-time"},
    "effective_at":{"type":"string","format":"date-time"},
    "recorded_at":{"type":"string","format":"date-time"},
    "proof":{"$ref":"#/$defs/Proof"},
    "extensions":{"type":"object"}
  },
  "$defs":{
    "Digest":{"type":"string","pattern":"^[0-9a-f]{64}$"},
    "Binding":{"type":"object","required":["artifact_id","revision","digest_algorithm","canonicalization","digest"],"properties":{"artifact_id":{"type":"string","minLength":1},"revision":{"type":"integer","minimum":1},"digest_algorithm":{"const":"sha-256"},"canonicalization":{"const":"RFC8785"},"digest":{"$ref":"#/$defs/Digest"}},"additionalProperties":false},
    "Proof":{"type":"object","required":["mode","verification_method","value"],"properties":{"mode":{"enum":["unsigned_fixture","jws","cose","vc"]},"verification_method":{"type":"string","minLength":1},"value":{"type":"string","minLength":1}},"additionalProperties":false}
  },
  "allOf":[
    {"if":{"properties":{"state_revision":{"const":1}},"required":["state_revision"]},"then":{"properties":{"previous_state_binding":{"type":"null"}}},"else":{"properties":{"previous_state_binding":{"$ref":"#/$defs/Binding"}}}},
    {"if":{"properties":{"status":{"const":"superseded"}},"required":["status"]},"then":{"required":["successor_definition_binding"]}}
  ],
  "additionalProperties":false
}
