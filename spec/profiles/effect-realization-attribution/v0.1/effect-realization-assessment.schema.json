{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://homeworldmodel.org/spec/profiles/effect-realization-attribution/v0.1/effect-realization-assessment.schema.json",
  "title":"HWM Effect Realization Assessment v0.1",
  "type":"object",
  "required":["contract","contract_version","assessment_id","effect_claim_binding","attempt_binding","evaluation_specification_binding","world_view_binding","as_of","assessment_window","criterion_results","result","observation_bindings","reason_codes","proof","extensions"],
  "properties":{
    "contract":{"const":"hwm-effect:RealizationAssessment"},"contract_version":{"const":"0.1.0"},
    "assessment_id":{"type":"string","minLength":1},"effect_claim_binding":{"$ref":"#/$defs/Binding"},"attempt_binding":{"$ref":"#/$defs/Binding"},"evaluation_specification_binding":{"$ref":"#/$defs/Binding"},"world_view_binding":{"$ref":"#/$defs/Binding"},
    "as_of":{"type":"string","format":"date-time"},"assessment_window":{"type":"object","required":["from","to"],"properties":{"from":{"type":"string","format":"date-time"},"to":{"type":"string","format":"date-time"}},"additionalProperties":false},
    "criterion_results":{"type":"array","minItems":1,"items":{"type":"object","required":["criterion_id","status","observation_bindings","reason_codes"],"properties":{"criterion_id":{"type":"string","minLength":1},"status":{"enum":["met","not_met","indeterminate"]},"observation_bindings":{"type":"array","uniqueItems":true,"items":{"$ref":"#/$defs/Binding"}},"reason_codes":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}}},"additionalProperties":false}},
    "result":{"enum":["realized","partially_realized","not_realized","indeterminate","not_applicable"]},
    "observation_bindings":{"type":"array","uniqueItems":true,"items":{"$ref":"#/$defs/Binding"}},"reason_codes":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}},
    "proof":{"$ref":"#/$defs/Proof"},"extensions":{"type":"object"}
  },
  "$defs":{"Digest":{"type":"string","pattern":"^[0-9a-f]{64}$"},"Binding":{"type":"object","required":["artifact_id","digest_algorithm","canonicalization","digest"],"properties":{"artifact_id":{"type":"string","minLength":1},"digest_algorithm":{"const":"sha-256"},"canonicalization":{"const":"RFC8785"},"digest":{"$ref":"#/$defs/Digest"}},"additionalProperties":false},"Proof":{"type":"object","required":["mode","verification_method","value"],"properties":{"mode":{"enum":["unsigned_fixture","jws","cose","vc"]},"verification_method":{"type":"string","minLength":1},"value":{"type":"string","minLength":1}},"additionalProperties":false}},
  "additionalProperties":false
}
