{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homeworldmodel.org/spec/profiles/evidence-standing/v0.1/evidence-standing-decision.schema.json",
  "title": "HWM Evidence Standing Decision v0.1",
  "type": "object",
  "required": ["contract", "contract_version", "decision_id", "record_binding", "purpose", "authority_epoch", "decided_at", "result", "source_binding_status", "proof_verification", "evidence_use", "matched_grant_ids", "qualification_evidence_ids", "admitted_assertions", "reason_codes", "proof", "extensions"],
  "properties": {
    "contract": { "const": "hwm-standing:Decision" },
    "contract_version": { "const": "0.1.0-fixture" },
    "decision_id": { "type": "string", "minLength": 1 },
    "record_binding": {
      "type": "object",
      "required": ["record_id", "digest_algorithm", "canonicalization", "digest"],
      "properties": {
        "record_id": { "type": "string", "minLength": 1 },
        "digest_algorithm": { "const": "sha-256" },
        "canonicalization": { "const": "RFC8785" },
        "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "purpose": { "type": "string", "minLength": 1 },
    "authority_epoch": { "type": "integer", "minimum": 0 },
    "decided_at": { "type": "string", "format": "date-time" },
    "result": { "enum": ["admitted", "excluded", "indeterminate"] },
    "source_binding_status": { "enum": ["verified", "invalid", "unavailable"] },
    "proof_verification": {
      "type": "object",
      "required": ["status", "verification_method"],
      "properties": {
        "status": { "enum": ["verified", "invalid", "unavailable"] },
        "verification_method": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "evidence_use": {
      "type": "object",
      "required": ["decision_id", "result"],
      "properties": {
        "decision_id": { "type": "string", "minLength": 1 },
        "result": { "enum": ["allowed", "denied", "indeterminate"] }
      },
      "additionalProperties": false
    },
    "matched_grant_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "qualification_evidence_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "admitted_assertions": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "reason_codes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "proof": {
      "type": "object",
      "required": ["mode", "verification_method"],
      "properties": {
        "mode": { "enum": ["unsigned_fixture", "digest", "signature", "vc"] },
        "verification_method": { "type": "string", "minLength": 1 },
        "value": { "type": "string" }
      },
      "additionalProperties": false
    },
    "extensions": { "type": "object", "additionalProperties": true }
  },
  "allOf": [
    {
      "if": { "properties": { "result": { "const": "admitted" } }, "required": ["result"] },
      "then": {
        "properties": {
          "source_binding_status": { "const": "verified" },
          "proof_verification": { "type": "object", "properties": { "status": { "const": "verified" } } },
          "evidence_use": { "type": "object", "properties": { "result": { "const": "allowed" } } },
          "matched_grant_ids": { "type": "array", "minItems": 1 },
          "admitted_assertions": { "type": "array", "minItems": 1 }
        }
      },
      "else": { "properties": { "admitted_assertions": { "type": "array", "maxItems": 0 } } }
    }
  ],
  "additionalProperties": false
}
