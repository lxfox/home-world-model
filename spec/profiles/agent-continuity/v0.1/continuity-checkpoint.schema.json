{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homeworldmodel.org/spec/profiles/agent-continuity/v0.1/continuity-checkpoint.schema.json",
  "title": "HWM Agent Continuity Checkpoint v0.1",
  "type": "object",
  "required": ["contract", "contract_version", "checkpoint_id", "task_id", "task_revision", "task_definition_binding", "mode", "generated_at", "valid_until", "authority_epoch", "source_context", "target_context", "durable_artifacts", "open_work", "uncertainty_items", "proof", "extensions"],
  "properties": {
    "contract": {"const": "hwm-continuity:Checkpoint"},
    "contract_version": {"const": "0.1.0-fixture"},
    "checkpoint_id": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "task_revision": {"type": "integer", "minimum": 1},
    "task_definition_binding": {"$ref": "#/$defs/TaskBinding"},
    "mode": {"enum": ["context_share", "successor", "delegated_acting", "exclusive_cutover"]},
    "generated_at": {"type": "string", "format": "date-time"},
    "valid_until": {"type": "string", "format": "date-time"},
    "authority_epoch": {"type": "integer", "minimum": 0},
    "source_context": {"$ref": "#/$defs/SourceContext"},
    "target_context": {"$ref": "#/$defs/TargetContext"},
    "durable_artifacts": {
      "type": "array",
      "items": {"$ref": "#/$defs/Artifact"}
    },
    "open_work": {
      "type": "array",
      "items": {"$ref": "#/$defs/OpenWork"}
    },
    "uncertainty_items": {
      "type": "array",
      "items": {"$ref": "#/$defs/Uncertainty"}
    },
    "proof": {"$ref": "#/$defs/Proof"},
    "extensions": {"type": "object", "additionalProperties": true}
  },
  "$defs": {
    "DigestBinding": {
      "type": "object",
      "required": ["artifact_id", "digest_algorithm", "canonicalization", "digest"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "digest_algorithm": {"const": "sha-256"},
        "canonicalization": {"const": "RFC8785"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "TaskBinding": {
      "type": "object",
      "required": ["task_id", "definition_revision", "digest_algorithm", "canonicalization", "digest"],
      "properties": {
        "task_id": {"type": "string", "minLength": 1},
        "definition_revision": {"type": "integer", "minimum": 1},
        "digest_algorithm": {"const": "sha-256"},
        "canonicalization": {"const": "RFC8785"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "SourceContext": {
      "type": "object",
      "required": ["subject_id", "admission_decision_binding", "world_view_binding"],
      "properties": {
        "subject_id": {"type": "string", "minLength": 1},
        "admission_decision_binding": {"$ref": "#/$defs/DigestBinding"},
        "world_view_binding": {"$ref": "#/$defs/DigestBinding"}
      },
      "additionalProperties": false
    },
    "TargetContext": {
      "type": "object",
      "required": ["subject_id", "admission_decision_binding", "purpose", "audience", "world_view_binding"],
      "properties": {
        "subject_id": {"type": "string", "minLength": 1},
        "admission_decision_binding": {"$ref": "#/$defs/DigestBinding"},
        "purpose": {"type": "string", "minLength": 1},
        "audience": {"type": "string", "minLength": 1},
        "world_view_binding": {"$ref": "#/$defs/DigestBinding"}
      },
      "additionalProperties": false
    },
    "Artifact": {
      "type": "object",
      "required": ["artifact_id", "digest_algorithm", "canonicalization", "digest", "role"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "digest_algorithm": {"const": "sha-256"},
        "canonicalization": {"const": "RFC8785"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "role": {"enum": ["claim_envelope", "record", "plan", "action_proposal", "action_trace", "assessment", "fixture"]}
      },
      "additionalProperties": false
    },
    "OpenWork": {
      "type": "object",
      "required": ["work_item_id", "kind", "status", "artifact_bindings", "reason_codes"],
      "properties": {
        "work_item_id": {"type": "string", "minLength": 1},
        "kind": {"enum": ["resolve", "plan", "propose_revision", "await_confirmation", "await_observation", "assess"]},
        "status": {"enum": ["open", "blocked", "indeterminate"]},
        "artifact_bindings": {"type": "array", "items": {"$ref": "#/$defs/DigestBinding"}},
        "reason_codes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}}
      },
      "additionalProperties": false
    },
    "Uncertainty": {
      "type": "object",
      "required": ["item_id", "proposition_ref", "epistemic_status", "reason_codes"],
      "properties": {
        "item_id": {"type": "string", "minLength": 1},
        "proposition_ref": {"type": "string", "minLength": 1},
        "epistemic_status": {"enum": ["unknown", "contested", "not_evaluated"]},
        "reason_codes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}}
      },
      "additionalProperties": false
    },
    "Proof": {
      "type": "object",
      "required": ["mode", "verification_method", "value"],
      "properties": {
        "mode": {"enum": ["unsigned_fixture", "signature"]},
        "verification_method": {"type": "string", "minLength": 1},
        "value": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
