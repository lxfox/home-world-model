{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://homeworldmodel.org/spec/profiles/deliberation-eligibility/v0.1/deliberation-eligibility-assessment.schema.json",
  "title":"HWM Deliberation Eligibility Assessment v0.1",
  "type":"object",
  "required":["contract","contract_version","assessment_id","household_id","purpose","assessed_at","as_of","authority_epoch","origin","world_view_binding","target_claim_binding","target_fit_assessment_binding","policy_claim_binding","target_fit_result","target_resolution","policy_resolution","operator","evaluation_coverage","condition_results","duplicate_status","existing_intent_status","result","reason_codes","proof","extensions"],
  "properties":{
    "contract":{"const":"hwm-deliberation:EligibilityAssessment"},
    "contract_version":{"const":"0.1.0-fixture"},
    "assessment_id":{"type":"string","minLength":1},
    "household_id":{"type":"string","minLength":1},
    "purpose":{"type":"string","minLength":1},
    "assessed_at":{"type":"string","format":"date-time"},
    "as_of":{"type":"string","format":"date-time"},
    "authority_epoch":{"type":"integer","minimum":0},
    "origin":{"const":"agent_detected_gap"},
    "world_view_binding":{"$ref":"#/$defs/Binding"},
    "target_claim_binding":{"$ref":"#/$defs/Binding"},
    "target_fit_assessment_binding":{"$ref":"#/$defs/Binding"},
    "policy_claim_binding":{"$ref":"#/$defs/Binding"},
    "target_fit_result":{"enum":["satisfied","partially_satisfied","not_satisfied","indeterminate"]},
    "target_resolution":{"$ref":"#/$defs/Resolution"},
    "policy_resolution":{"$ref":"#/$defs/Resolution"},
    "operator":{"enum":["all_of","any_of","unconditional_after_gap"]},
    "evaluation_coverage":{"enum":["complete","decisive_subset","partial"]},
    "condition_results":{"type":"array","items":{"$ref":"#/$defs/Condition"}},
    "duplicate_status":{"enum":["none","open_deliberation","cooldown_active","existing_work","indeterminate"]},
    "existing_intent_status":{"enum":["none","adopted_for_exact_target","other","indeterminate"]},
    "result":{"enum":["eligible","not_eligible","indeterminate"]},
    "reason_codes":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}},
    "proof":{"$ref":"#/$defs/Proof"},
    "extensions":{"type":"object","additionalProperties":true}
  },
  "allOf":[
    {"if":{"properties":{"result":{"const":"eligible"}}},"then":{"properties":{"target_fit_result":{"enum":["not_satisfied","partially_satisfied"]},"target_resolution":{"$ref":"#/$defs/Qualified"},"policy_resolution":{"$ref":"#/$defs/Qualified"},"duplicate_status":{"const":"none"},"existing_intent_status":{"enum":["none","other"]},"evaluation_coverage":{"enum":["complete","decisive_subset"]}}}},
    {"if":{"properties":{"operator":{"const":"unconditional_after_gap"}}},"then":{"properties":{"evaluation_coverage":{"const":"complete"},"condition_results":{"type":"array","maxItems":0}}},"else":{"properties":{"condition_results":{"type":"array","minItems":1}}}},
    {"if":{"properties":{"duplicate_status":{"enum":["open_deliberation","cooldown_active","existing_work"]}}},"then":{"properties":{"result":{"const":"not_eligible"}}}},
    {"if":{"properties":{"existing_intent_status":{"const":"adopted_for_exact_target"}}},"then":{"properties":{"result":{"const":"not_eligible"}}}}
  ],
  "$defs":{
    "Binding":{"type":"object","required":["artifact_id","content_scope","digest_algorithm","canonicalization","digest"],"properties":{"artifact_id":{"type":"string","minLength":1},"content_scope":{"enum":["artifact","claim_body"]},"digest_algorithm":{"const":"sha-256"},"canonicalization":{"const":"RFC8785"},"digest":{"type":"string","pattern":"^[0-9a-f]{64}$"}},"additionalProperties":false},
    "Resolution":{"type":"object","required":["resolution_id","availability_status","epistemic_status","freshness_status","temporal_status"],"properties":{"resolution_id":{"type":"string","minLength":1},"availability_status":{"enum":["available","not_observed","source_unavailable","access_denied"]},"epistemic_status":{"enum":["accepted","contested","unknown","not_verified","not_evaluated"]},"freshness_status":{"enum":["current","stale","not_applicable","unknown"]},"temporal_status":{"enum":["in_effect","not_yet_in_effect","expired","unbounded","mixed","indeterminate"]}},"additionalProperties":false},
    "Qualified":{"allOf":[{"$ref":"#/$defs/Resolution"},{"type":"object","properties":{"availability_status":{"const":"available"},"epistemic_status":{"const":"accepted"},"freshness_status":{"enum":["current","not_applicable"]},"temporal_status":{"enum":["in_effect","unbounded"]}}}]},
    "Condition":{"type":"object","required":["condition_id","assessment_binding","observed_result","reason_codes"],"properties":{"condition_id":{"type":"string","minLength":1},"assessment_binding":{"oneOf":[{"type":"null"},{"$ref":"#/$defs/Binding"}]},"observed_result":{"enum":["satisfied","not_satisfied","indeterminate"]},"reason_codes":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}}},"additionalProperties":false},
    "Proof":{"type":"object","required":["mode","verification_method","value"],"properties":{"mode":{"enum":["unsigned_fixture","jws","cose","vc"]},"verification_method":{"type":"string","minLength":1},"value":{"type":"string","minLength":1}},"additionalProperties":false}
  },
  "additionalProperties":false
}
