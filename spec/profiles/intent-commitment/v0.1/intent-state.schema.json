{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homeworldmodel.org/spec/profiles/intent-commitment/v0.1/intent-state.schema.json",
  "title": "HWM Intent State Assessment v0.1",
  "type": "object",
  "required": ["contract", "contract_version", "state_id", "intent_id", "state_revision", "previous_state_binding", "intent_definition_binding", "assessed_at", "as_of", "authority_epoch", "commitment_status", "fulfillment_status", "commitment_decision_binding", "expectation_results", "active_task_bindings", "transition_record_binding", "related_intent_bindings", "proof", "extensions"],
  "properties": {
    "contract": {"const": "hwm-intent:StateAssessment"},
    "contract_version": {"const": "0.1.0-fixture"},
    "state_id": {"type": "string", "minLength": 1},
    "intent_id": {"type": "string", "minLength": 1},
    "state_revision": {"type": "integer", "minimum": 1},
    "previous_state_binding": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/DigestBinding"}]},
    "intent_definition_binding": {"$ref": "#/$defs/IntentBinding"},
    "assessed_at": {"type": "string", "format": "date-time"},
    "as_of": {"type": "string", "format": "date-time"},
    "authority_epoch": {"type": "integer", "minimum": 0},
    "commitment_status": {"enum": ["proposed", "adopted", "suspended", "retracted", "superseded", "indeterminate"]},
    "fulfillment_status": {"enum": ["not_evaluated", "not_started", "ongoing", "fulfilled", "not_fulfilled", "degraded", "indeterminate"]},
    "commitment_decision_binding": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/DigestBinding"}]},
    "expectation_results": {"type": "array", "items": {"$ref": "#/$defs/ExpectationResult"}},
    "active_task_bindings": {"type": "array", "items": {"$ref": "#/$defs/TaskBinding"}},
    "transition_record_binding": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/DigestBinding"}]},
    "related_intent_bindings": {"type": "array", "items": {"$ref": "#/$defs/IntentBinding"}},
    "proof": {"$ref": "#/$defs/Proof"},
    "extensions": {"type": "object", "additionalProperties": true}
  },
  "$defs": {
    "DigestBinding": {
      "type": "object",
      "required": ["artifact_id", "digest_algorithm", "canonicalization", "digest"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "digest_algorithm": {"const": "sha-256"},
        "canonicalization": {"const": "RFC8785"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "IntentBinding": {
      "type": "object",
      "required": ["intent_id", "definition_revision", "digest_algorithm", "canonicalization", "digest"],
      "properties": {
        "intent_id": {"type": "string", "minLength": 1},
        "definition_revision": {"type": "integer", "minimum": 1},
        "digest_algorithm": {"const": "sha-256"},
        "canonicalization": {"const": "RFC8785"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "TaskBinding": {
      "type": "object",
      "required": ["task_id", "definition_revision", "digest_algorithm", "canonicalization", "digest"],
      "properties": {
        "task_id": {"type": "string", "minLength": 1},
        "definition_revision": {"type": "integer", "minimum": 1},
        "digest_algorithm": {"const": "sha-256"},
        "canonicalization": {"const": "RFC8785"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "ExpectationResult": {
      "type": "object",
      "required": ["expectation_id", "result", "evidence_bindings"],
      "properties": {
        "expectation_id": {"type": "string", "minLength": 1},
        "result": {"enum": ["satisfied", "unsatisfied", "indeterminate", "not_due"]},
        "evidence_bindings": {"type": "array", "items": {"$ref": "#/$defs/DigestBinding"}}
      },
      "additionalProperties": false
    },
    "Proof": {
      "type": "object",
      "required": ["mode", "verification_method", "value"],
      "properties": {
        "mode": {"enum": ["unsigned_fixture", "signature"]},
        "verification_method": {"type": "string", "minLength": 1},
        "value": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {"properties": {"state_revision": {"const": 1}}, "required": ["state_revision"]},
      "then": {"properties": {"previous_state_binding": {"type": "null"}}},
      "else": {"properties": {"previous_state_binding": {"$ref": "#/$defs/DigestBinding"}}}
    }
  ],
  "additionalProperties": false
}
