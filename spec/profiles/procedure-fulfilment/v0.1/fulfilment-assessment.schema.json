{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homeworldmodel.org/spec/profiles/procedure-fulfilment/v0.1/fulfilment-assessment.schema.json",
  "title": "HWM Procedure Fulfilment Assessment v0.1",
  "type": "object",
  "required": ["contract", "contract_version", "assessment_id", "requirement_set_id", "proposal_id", "proposal_revision", "authority_epoch", "assessment_time", "stage", "procedure_status", "authority_gate", "fulfilled_requirement_ids", "pending_requirement_ids", "negative_requirement_ids", "unfulfilled_requirement_ids", "indeterminate_requirement_ids", "not_due_requirement_ids", "evaluated_record_ids", "evaluated_standing_decision_ids", "reason_codes", "proof", "extensions"],
  "properties": {
    "contract": { "const": "hwm-fulfilment:Assessment" },
    "contract_version": { "const": "0.1.0-fixture" },
    "assessment_id": { "type": "string", "minLength": 1 },
    "requirement_set_id": { "type": "string", "minLength": 1 },
    "proposal_id": { "type": "string", "minLength": 1 },
    "proposal_revision": { "type": "integer", "minimum": 1 },
    "authority_epoch": { "type": "integer", "minimum": 0 },
    "assessment_time": { "type": "string", "format": "date-time" },
    "stage": { "enum": ["pre_authorization", "pre_dispatch", "post_execution"] },
    "procedure_status": { "enum": ["satisfied", "pending", "blocked", "indeterminate", "post_action_noncompliance"] },
    "authority_gate": { "enum": ["continue_policy_evaluation", "confirmation_required", "requirements_pending", "denied", "indeterminate", "historical_noncompliance"] },
    "fulfilled_requirement_ids": { "$ref": "#/$defs/UniqueStrings" },
    "pending_requirement_ids": { "$ref": "#/$defs/UniqueStrings" },
    "negative_requirement_ids": { "$ref": "#/$defs/UniqueStrings" },
    "unfulfilled_requirement_ids": { "$ref": "#/$defs/UniqueStrings" },
    "indeterminate_requirement_ids": { "$ref": "#/$defs/UniqueStrings" },
    "not_due_requirement_ids": { "$ref": "#/$defs/UniqueStrings" },
    "evaluated_record_ids": { "$ref": "#/$defs/UniqueStrings" },
    "evaluated_standing_decision_ids": { "$ref": "#/$defs/UniqueStrings" },
    "reason_codes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "proof": { "$ref": "#/$defs/Proof" },
    "extensions": { "type": "object", "additionalProperties": true }
  },
  "$defs": {
    "UniqueStrings": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "Proof": {
      "type": "object",
      "required": ["mode", "verification_method"],
      "properties": {
        "mode": { "enum": ["unsigned_fixture", "digest", "signature", "vc"] },
        "verification_method": { "type": "string", "minLength": 1 },
        "value": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
