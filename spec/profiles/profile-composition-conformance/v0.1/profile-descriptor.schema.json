{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://homeworldmodel.org/spec/profiles/profile-composition-conformance/v0.1/profile-descriptor.schema.json",
  "title":"HWM Profile Descriptor v0.1",
  "type":"object",
  "required":["profile_id","version","normative_document","document_digest","artifacts","roles","dependencies","incompatibilities","invariants","issued_at","proof_refs"],
  "properties":{
    "profile_id":{"type":"string","format":"uri"},
    "version":{"type":"string","pattern":"^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "status":{"type":"string"},
    "normative_document":{"type":"string","format":"uri"},
    "normative_document_path":{"type":"string","minLength":1},
    "document_digest":{"type":"string","minLength":16},
    "artifacts":{"type":"array","items":{"type":"object","required":["artifact_type","schema_refs"],"properties":{"artifact_type":{"type":"string"},"schema_refs":{"type":"array","items":{"type":"string"},"uniqueItems":true}},"additionalProperties":true}},
    "roles":{"type":"array","items":{"enum":["preserve","consume","produce","evaluate","procedure_adapter"]},"uniqueItems":true},
    "dependencies":{"type":"array","items":{"type":"object","required":["profile_id","version","kind"],"properties":{"profile_id":{"type":"string"},"version":{"type":"string"},"kind":{"enum":["required","conditional","optional"]},"activation_condition":{"type":["object","null"]}},"additionalProperties":false}},
    "incompatibilities":{"type":"array","items":{"type":"object","required":["profile_id","version"],"properties":{"profile_id":{"type":"string"},"version":{"type":"string"},"reason":{"type":"string"}},"additionalProperties":false}},
    "invariants":{"type":"array","minItems":1,"items":{"type":"string"},"uniqueItems":true},
    "offline_resource_refs":{"type":"array","items":{"type":"string"},"uniqueItems":true},
    "unknown_extension_behavior":{"enum":["preserve","reject","profile_defined"]},
    "issued_at":{"type":"string","format":"date-time"},
    "proof_refs":{"type":"array","items":{"type":"string"},"uniqueItems":true}
  },
  "additionalProperties":false
}
