{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homeworldmodel.org/spec/profiles/agent-admission/v0.1/agent-admission-decision.schema.json",
  "title": "HWM Agent Admission Decision v0.1",
  "type": "object",
  "required": ["contract", "contract_version", "decision_id", "request_binding", "decided_at", "trust_root_binding", "authority_epoch", "compatibility", "instance_binding", "authorization_decision", "assigned_subject_id", "granted_scope", "issued_lease_binding", "reason_codes", "proof", "extensions"],
  "properties": {
    "contract": { "const": "hwm-admission:Decision" },
    "contract_version": { "const": "0.1.0-fixture" },
    "decision_id": { "type": "string", "minLength": 1 },
    "request_binding": { "$ref": "#/$defs/DigestBinding" },
    "decided_at": { "type": "string", "format": "date-time" },
    "trust_root_binding": {
      "type": "object",
      "required": ["lineage_id", "root_id", "root_version", "authority_epoch_floor"],
      "properties": {
        "lineage_id": { "type": "string", "minLength": 1 },
        "root_id": { "type": "string", "minLength": 1 },
        "root_version": { "type": "integer", "minimum": 1 },
        "authority_epoch_floor": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "authority_epoch": { "type": "integer", "minimum": 0 },
    "compatibility": {
      "type": "object",
      "required": ["status", "matched_profile_ids", "missing_required_profile_ids", "unsupported_optional_profile_ids", "canonicalization", "proof_suite"],
      "properties": {
        "status": { "enum": ["compatible", "incompatible", "indeterminate"] },
        "matched_profile_ids": { "$ref": "#/$defs/UniqueStrings" },
        "missing_required_profile_ids": { "$ref": "#/$defs/UniqueStrings" },
        "unsupported_optional_profile_ids": { "$ref": "#/$defs/UniqueStrings" },
        "canonicalization": { "type": ["string", "null"] },
        "proof_suite": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "instance_binding": {
      "type": "object",
      "required": ["status", "binding_type", "value", "verification_method"],
      "properties": {
        "status": { "enum": ["verified", "invalid", "indeterminate"] },
        "binding_type": { "enum": ["jwk_thumbprint", "cose_key_thumbprint", "platform_key_ref", "fixture"] },
        "value": { "type": "string", "minLength": 1 },
        "verification_method": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "authorization_decision": { "enum": ["allowed", "denied", "confirmation_required", "indeterminate"] },
    "assigned_subject_id": { "type": ["string", "null"], "minLength": 1 },
    "granted_scope": {
      "type": "object",
      "required": ["purposes", "actions", "audiences"],
      "properties": {
        "purposes": { "$ref": "#/$defs/UniqueStrings" },
        "actions": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["resolve_view", "propose_action", "dispatch_action", "submit_record"] }
        },
        "audiences": { "$ref": "#/$defs/UniqueStrings" }
      },
      "additionalProperties": false
    },
    "issued_lease_binding": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/DigestBinding" }
      ]
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "proof": {
      "type": "object",
      "required": ["mode", "verification_method", "value"],
      "properties": {
        "mode": { "enum": ["unsigned_fixture", "signature", "vc", "cwt"] },
        "verification_method": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "extensions": { "type": "object", "additionalProperties": true }
  },
  "$defs": {
    "UniqueStrings": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "DigestBinding": {
      "type": "object",
      "required": ["artifact_id", "digest_algorithm", "canonicalization", "digest"],
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 },
        "digest_algorithm": { "const": "sha-256" },
        "canonicalization": { "const": "RFC8785" },
        "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": { "properties": { "authorization_decision": { "const": "allowed" } }, "required": ["authorization_decision"] },
      "then": {
        "properties": {
          "compatibility": { "type": "object", "properties": { "status": { "const": "compatible" } } },
          "instance_binding": { "type": "object", "properties": { "status": { "const": "verified" } } },
          "assigned_subject_id": { "type": "string" },
          "granted_scope": {
            "type": "object",
            "properties": {
              "purposes": { "type": "array", "minItems": 1 },
              "actions": { "type": "array", "minItems": 1 },
              "audiences": { "type": "array", "minItems": 1 }
            }
          },
          "issued_lease_binding": { "$ref": "#/$defs/DigestBinding" }
        }
      },
      "else": {
        "properties": {
          "granted_scope": {
            "type": "object",
            "properties": {
              "purposes": { "type": "array", "maxItems": 0 },
              "actions": { "type": "array", "maxItems": 0 },
              "audiences": { "type": "array", "maxItems": 0 }
            }
          },
          "issued_lease_binding": { "type": "null" }
        }
      }
    }
  ],
  "additionalProperties": false
}
