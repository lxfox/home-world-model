{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homeworldmodel.org/spec/profiles/routine-instantiation/v0.1/routine-definition.schema.json",
  "title": "HWM Routine Instantiation Definition v0.1",
  "type": "object",
  "required": ["contract", "contract_version", "routine_id", "definition_revision", "previous_definition_binding", "identity_basis", "identity_basis_digest", "target_intent_binding", "trigger_contract", "task_template", "instantiation_policy", "revision", "created_at", "created_by_subject", "proof", "extensions"],
  "properties": {
    "contract": {"const": "hwm-routine:Definition"},
    "contract_version": {"const": "0.1.0-fixture"},
    "routine_id": {"type": "string", "minLength": 1},
    "definition_revision": {"type": "integer", "minimum": 1},
    "previous_definition_binding": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/DigestBinding"}]},
    "identity_basis": {"$ref": "#/$defs/IdentityBasis"},
    "identity_basis_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "target_intent_binding": {"$ref": "#/$defs/IntentBinding"},
    "trigger_contract": {"$ref": "#/$defs/TriggerContract"},
    "task_template": {"$ref": "#/$defs/TaskTemplate"},
    "instantiation_policy": {"$ref": "#/$defs/InstantiationPolicy"},
    "revision": {"$ref": "#/$defs/Revision"},
    "created_at": {"type": "string", "format": "date-time"},
    "created_by_subject": {"type": "string", "minLength": 1},
    "proof": {"$ref": "#/$defs/Proof"},
    "extensions": {"type": "object", "additionalProperties": true}
  },
  "$defs": {
    "DigestBinding": {
      "type": "object",
      "required": ["artifact_id", "digest_algorithm", "canonicalization", "digest"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "digest_algorithm": {"const": "sha-256"},
        "canonicalization": {"const": "RFC8785"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "IntentBinding": {
      "type": "object",
      "required": ["intent_id", "definition_revision", "digest_algorithm", "canonicalization", "digest"],
      "properties": {
        "intent_id": {"type": "string", "minLength": 1},
        "definition_revision": {"type": "integer", "minimum": 1},
        "digest_algorithm": {"const": "sha-256"},
        "canonicalization": {"const": "RFC8785"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "IdentityBasis": {
      "type": "object",
      "required": ["household_id", "target_intent_id", "purpose", "scope_refs"],
      "properties": {
        "household_id": {"type": "string", "minLength": 1},
        "target_intent_id": {"type": "string", "minLength": 1},
        "purpose": {"type": "string", "minLength": 1},
        "scope_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    },
    "TriggerContract": {
      "type": "object",
      "required": ["kind", "trigger_spec_binding", "eligibility_spec_binding", "occurrence_key_policy_binding", "semantics_uri"],
      "properties": {
        "kind": {"enum": ["temporal_recurrence", "event", "state_transition", "forecast_assessment", "composite"]},
        "trigger_spec_binding": {"$ref": "#/$defs/DigestBinding"},
        "eligibility_spec_binding": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/DigestBinding"}]},
        "occurrence_key_policy_binding": {"$ref": "#/$defs/DigestBinding"},
        "semantics_uri": {"type": "string", "format": "uri"}
      },
      "additionalProperties": false
    },
    "ExitCriterion": {
      "type": "object",
      "required": ["criterion_id", "kind", "mandatory", "target_binding"],
      "properties": {
        "criterion_id": {"type": "string", "minLength": 1},
        "kind": {"enum": ["world_view_resolution", "goal_evaluation", "record_present", "proposal_terminal", "manual_acceptance"]},
        "mandatory": {"type": "boolean"},
        "target_binding": {"$ref": "#/$defs/DigestBinding"}
      },
      "additionalProperties": false
    },
    "TaskTemplate": {
      "type": "object",
      "required": ["purpose", "scope_refs", "exit_criteria"],
      "properties": {
        "purpose": {"type": "string", "minLength": 1},
        "scope_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "exit_criteria": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/ExitCriterion"}}
      },
      "additionalProperties": false
    },
    "InstantiationPolicy": {
      "type": "object",
      "required": ["late_mode", "max_lateness_seconds", "catch_up_limit", "overlap_mode"],
      "properties": {
        "late_mode": {"enum": ["skip", "latest_only", "bounded_each"]},
        "max_lateness_seconds": {"type": "integer", "minimum": 0},
        "catch_up_limit": {"type": "integer", "minimum": 0},
        "overlap_mode": {"enum": ["independent", "suppress_while_active", "defer_while_active"]}
      },
      "allOf": [
        {
          "if": {"type": "object", "properties": {"late_mode": {"const": "skip"}}, "required": ["late_mode"]},
          "then": {"type": "object", "properties": {"catch_up_limit": {"const": 0}}}
        },
        {
          "if": {"type": "object", "properties": {"late_mode": {"const": "latest_only"}}, "required": ["late_mode"]},
          "then": {"type": "object", "properties": {"catch_up_limit": {"const": 1}}}
        },
        {
          "if": {"type": "object", "properties": {"late_mode": {"const": "bounded_each"}}, "required": ["late_mode"]},
          "then": {"type": "object", "properties": {"catch_up_limit": {"type": "integer", "minimum": 1}}}
        }
      ],
      "additionalProperties": false
    },
    "Revision": {
      "type": "object",
      "required": ["relation", "continuity_decision_binding"],
      "properties": {
        "relation": {"enum": ["genesis", "revision"]},
        "continuity_decision_binding": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/DigestBinding"}]}
      },
      "allOf": [
        {
          "if": {"type": "object", "properties": {"relation": {"const": "genesis"}}, "required": ["relation"]},
          "then": {"type": "object", "properties": {"continuity_decision_binding": {"type": "null"}}},
          "else": {"type": "object", "properties": {"continuity_decision_binding": {"$ref": "#/$defs/DigestBinding"}}}
        }
      ],
      "additionalProperties": false
    },
    "Proof": {
      "type": "object",
      "required": ["mode", "verification_method", "value"],
      "properties": {
        "mode": {"enum": ["unsigned_fixture", "signature"]},
        "verification_method": {"type": "string", "minLength": 1},
        "value": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {"type": "object", "properties": {"definition_revision": {"const": 1}}, "required": ["definition_revision"]},
      "then": {"type": "object", "properties": {"previous_definition_binding": {"type": "null"}, "revision": {"type": "object", "properties": {"relation": {"const": "genesis"}}}}},
      "else": {"type": "object", "properties": {"previous_definition_binding": {"$ref": "#/$defs/DigestBinding"}, "revision": {"type": "object", "properties": {"relation": {"const": "revision"}}}}}
    }
  ],
  "additionalProperties": false
}
