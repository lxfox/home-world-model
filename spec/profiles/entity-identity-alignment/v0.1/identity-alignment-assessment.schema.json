{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://homeworldmodel.org/spec/profiles/entity-identity-alignment/v0.1/identity-alignment-assessment.schema.json",
  "title":"HWM Identity Alignment Assessment v0.1",
  "type":"object",
  "required":["contract","contract_version","assessment_id","request_digest","evidence_bundle_digest","purpose","as_of","authority_epoch","type_compatibility","temporal_status","namespace_status","origin_independence","evidence_sufficiency","result","relation","allowed_consequences","limitations","reason_codes","assessed_at","proof","extensions"],
  "properties":{
    "contract":{"const":"hwm-identity:AlignmentAssessment"},"contract_version":{"const":"0.1.0"},
    "assessment_id":{"type":"string","minLength":1},"request_digest":{"$ref":"#/$defs/Digest"},"evidence_bundle_digest":{"$ref":"#/$defs/Digest"},
    "purpose":{"type":"string","minLength":1},"as_of":{"type":"string","format":"date-time"},"authority_epoch":{"type":"integer","minimum":0},
    "type_compatibility":{"enum":["same_kind","cross_kind_relation_only","incompatible","indeterminate"]},
    "temporal_status":{"enum":["aligned","not_aligned","indeterminate"]},
    "namespace_status":{"enum":["valid_for_scope","collision_detected","reassignment_detected","insufficient","indeterminate"]},
    "origin_independence":{"enum":["sufficient","correlated","insufficient","indeterminate"]},
    "evidence_sufficiency":{"enum":["sufficient","insufficient","conflicting","indeterminate"]},
    "result":{"enum":["same_entity","distinct_entities","related_not_identical","unresolved","integrity_conflict"]},
    "relation":{"enum":["none","asset_realizes_function_position","asset_exposes_endpoint","asset_instance_of_product_model","representation_depicts_space","asset_replaces_asset","endpoint_supersedes_endpoint","part_of","co_located_with","functionally_substitutable_for"]},
    "allowed_consequences":{"type":"array","uniqueItems":true,"items":{"enum":["none","propose_same_entity_claim","propose_distinct_entity_claim","propose_typed_relation_claim","qualify_reference_for_declared_use","trigger_dependency_revalidation"]}},
    "limitations":{"type":"array","items":{"type":"string","minLength":1}},"reason_codes":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}},
    "assessed_at":{"type":"string","format":"date-time"},"proof":{"$ref":"#/$defs/Proof"},"extensions":{"type":"object"}
  },
  "$defs":{"Digest":{"type":"string","pattern":"^[0-9a-f]{64}$"},"Proof":{"type":"object","required":["mode","verification_method","value"],"properties":{"mode":{"enum":["unsigned_fixture","jws","cose","vc"]},"verification_method":{"type":"string","minLength":1},"value":{"type":"string","minLength":1}},"additionalProperties":false}},
  "allOf":[
    {"if":{"properties":{"result":{"const":"same_entity"}},"required":["result"]},"then":{"properties":{"type_compatibility":{"const":"same_kind"},"relation":{"const":"none"},"evidence_sufficiency":{"const":"sufficient"}}}},
    {"if":{"properties":{"result":{"const":"related_not_identical"}},"required":["result"]},"then":{"properties":{"relation":{"not":{"const":"none"}}}}},
    {"if":{"properties":{"result":{"enum":["distinct_entities","unresolved","integrity_conflict"]}},"required":["result"]},"then":{"properties":{"relation":{"const":"none"}}}}
  ],
  "additionalProperties":false
}
